# keeper-mcp environment variables.
#
# The server does NOT load this file (no dotenv). Supply values through the MCP
# client config, e.g.:  claude mcp add keeper -e KEEPER_CONFIG_FILE=... -- ...
# All variables are optional; the defaults below are what the server assumes.

# Path to the Keeper Commander persistent-login config file created by the
# one-time bootstrap (see README.md "Authentication bootstrap").
KEEPER_CONFIG_FILE=~/.keeper/config.json

# Keeper Commander executable. Defaults to "keeper"; the copy installed into
# this project's virtualenv is auto-detected, so this rarely needs setting.
KEEPER_COMMANDER_BIN=keeper

# Per-command timeout in seconds. Commander logs in and syncs the vault on
# every call, so large vaults/reports may need more.
KEEPER_COMMAND_TIMEOUT=120
